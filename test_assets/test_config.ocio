ocio_profile_version: 2

environment:
  {}

search_path: ""

roles:
  default: linear

file_rules:
  - !<Rule> {name: Default, colorspace: default}

displays:
  sRGB:
    - !<View> {name: Raw, colorspace: source_log}

colorspaces:
  - !<ColorSpace>
    name: source_log
    family: ""
    equalitygroup: ""
    bitdepth: 32f
    description: "A log-like space — matrix halves values"
    isdata: false
    allocation: uniform
    to_reference: !<MatrixTransform> {matrix: [0.5, 0, 0, 0, 0, 0.5, 0, 0, 0, 0, 0.5, 0, 0, 0, 0, 1]}

  - !<ColorSpace>
    name: linear
    family: ""
    equalitygroup: ""
    bitdepth: 32f
    description: "Linear reference space (identity to reference)"
    isdata: false
    allocation: uniform
